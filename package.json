{
  "name": "associacao-verde-production-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "next start",
    "dev": "next dev",
    "next:build": "next build",
    "test": "node --import tsx --test test/*.test.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "smoke": "node --import tsx scripts/smoke-production-app.mjs",
    "e2e": "python3 scripts/e2e-production-app.py",
    "dev:reset": "node --import tsx scripts/reset-dev-data.mjs",
    "readiness:backup-drill": "node --import tsx scripts/backup-restore-drill.mjs",
    "readiness:webhook-drill": "node --import tsx scripts/webhook-drill.mjs",
    "readiness:provider-evidence": "node --import tsx scripts/provider-evidence.mjs",
    "readiness:deployment-check": "node --import tsx scripts/deployment-check.mjs",
    "readiness:backup-schedule": "node --import tsx scripts/backup-schedule-evidence.mjs",
    "readiness:domain-tls": "node --import tsx scripts/domain-tls-check.mjs",
    "readiness:schema-check": "node --import tsx scripts/schema-check.mjs",
    "readiness:session-security": "node --import tsx scripts/session-security-check.mjs",
    "readiness:release-gate": "node --import tsx scripts/release-gate.mjs",
    "verify:isolated": "node --import tsx scripts/verify-isolated.mjs",
    "import:archive": "node --import tsx scripts/import-archive.mjs",
    "check:px": "node scripts/check-px-discipline.mjs",
    "check": "npm run lint --silent && npm run format:check --silent && npm run typecheck --silent && npm run check:px --silent && node --check scripts/smoke-production-app.mjs && node --check scripts/import-archive.mjs && node --check scripts/reset-dev-data.mjs && node --check scripts/backup-restore-drill.mjs && node --check scripts/webhook-drill.mjs && node --check scripts/provider-evidence.mjs && node --check scripts/deployment-check.mjs && node --check scripts/backup-schedule-evidence.mjs && node --check scripts/domain-tls-check.mjs && node --check scripts/schema-check.mjs && node --check scripts/session-security-check.mjs && node --check scripts/release-gate.mjs && node --check scripts/verify-isolated.mjs && node --check scripts/check-px-discipline.mjs && python3 -m py_compile scripts/e2e-production-app.py && next build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.6",
    "@types/node": "^22.19.18",
    "@types/react": "19.2.14",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
